# ── Preprocessed data & client splits ────────────────────────────────────────
# Regenerated by: python data_processing/download_data.py
#                 python data_processing/create_noniid_splits.py
data/*.pkl

# ── Trained models ────────────────────────────────────────────────────────────
# Regenerated by: python experiments/baseline_fl_demo.py (and future phases)
results/models/*.pt
results/models/*.pth

# ── Experiment logs & plots ───────────────────────────────────────────────────
# CSV logs and PNG plots are generated at runtime with timestamps.
# Commit only the final/selected ones manually if needed for the paper.
results/logs/*.csv
results/plots/*.png

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/

# ── Jupyter artefacts ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Secrets / credentials (never commit these) ───────────────────────────────
.env
*.key
secrets.json
